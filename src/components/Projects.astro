---
import Project from "./Project.astro";
import ProjectFilters from "./project/ProjectFilters.astro";
import { PROJECTS } from "@/data/projects";
---

<div class="flex flex-col gap-y-10">
  <ProjectFilters />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-x-8 md:gap-y-12" id="projects-grid">
    {
      PROJECTS.map((project) => (
        <Project
          title={project.title}
          description={project.description}
          tags={project.tags}
          category={project.category}
          role={project.role as "fullstack" | "frontend" | undefined}
          image={project.image}
          link={project.link}
          progres={project.progres}
        />
      ))
    }
  </div>
</div>

<style>
  .projects-filter {
    border: none;
    cursor: pointer;
    padding: 0;
    background: none;
  }
</style>

<script>
  const filterButtons = document.querySelectorAll<HTMLElement>(".projects-filter");
  const projectCards = document.querySelectorAll<HTMLElement>(".projects-card");

  function setActiveButton(active: HTMLElement) {
    filterButtons.forEach((btn) => {
      btn.classList.remove("is-active");
      const root = btn.querySelector(".badge-root");
      if (root) root.classList.add("badge--inactive");
    });
    active.classList.add("is-active");
    const activeRoot = active.querySelector(".badge-root");
    if (activeRoot) activeRoot.classList.remove("badge--inactive");
  }

  function filterProjects(category: string) {
    projectCards.forEach((card) => {
      const cardCategory = card.getAttribute("data-category");
      const show = category === "todos" || cardCategory === category;
      card.style.display = show ? "" : "none";
    });
  }

  const todosButton = document.querySelector<HTMLElement>('.projects-filter[data-category="todos"]');

  filterButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.getAttribute("data-category") ?? "todos";
      const isAlreadyActive = btn.classList.contains("is-active");

      if (isAlreadyActive && todosButton) {
        setActiveButton(todosButton);
        filterProjects("todos");
      } else {
        setActiveButton(btn);
        filterProjects(category);
      }
    });
  });
</script>
